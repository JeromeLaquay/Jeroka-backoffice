# Copier vers .env.e2e.local (non versionné) et renseigner les valeurs.
# Playwright charge .env.e2e.local puis .env.e2e au démarrage (voir playwright.config.ts).

PLAYWRIGHT_BASE_URL=http://localhost:3001

# Compte valide sur l’API (obligatoire, sans guillemets). Exemple :
# PLAYWRIGHT_EMAIL=utilisateur@example.com
# PLAYWRIGHT_PASSWORD=motdepasse
PLAYWRIGHT_EMAIL=
PLAYWRIGHT_PASSWORD=

# Optionnel : compte administrateur (sinon les tests admin sont ignorés si le menu Admin est absent)
# PLAYWRIGHT_ADMIN_EMAIL=
# PLAYWRIGHT_ADMIN_PASSWORD=
